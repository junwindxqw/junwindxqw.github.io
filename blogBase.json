c31\u662f\u4ece\u4e00\u884c\u7684\u5f00\u5934\u3002", "top": 0, "createdAt": 1774771255, "style": "", "script": "<script src='https://junwindxqw.github.io/assets/backtop.js'></script><script src='https://junwindxqw.github.io/assets/articletoc.js'></script><script src='https://junwindxqw.github.io/assets/lightbox.js'></script>", "head": "", "ogImage": "https://github.com/junwindxqw.png", "createdDate": "2026-03-29", "dateLabelColor": "#1f883d"}, "P15": {"htmlDir": "docs/post/webstorm-da-kai-vue2-xiang-mu-bao-hong.html", "labels": ["webstorm", "jetbrains"], "postTitle": "webstorm\u6253\u5f00vue2\u9879\u76ee\u62a5\u7ea2", "postUrl": "post/webstorm-da-kai-vue2-xiang-mu-bao-hong.html", "postSourceUrl": "https://github.com/junwindxqw/junwindxqw.github.io/issues/15", "commentNum": 0, "wordCount": 295, "description": " likeshop\u9879\u76ee   vue2 + elementUi\n\n<img width='461' height='229' alt='Image' src='https://github.com/user-attachments/assets/3ee03eef-7d8e-4b0e-9bfd-e12398f85b45' />\n\n<img width='989' height='728' alt='Image' src='https://github.com/user-attachments/assets/a637ea39-cf56-42c0-83ce-c318020b46ba' />\n\u3002", "top": 0, "createdAt": 1774771634, "style": "", "script": "<script src='https://junwindxqw.github.io/assets/backtop.js'></script><script src='https://junwindxqw.github.io/assets/articletoc.js'></script><script src='https://junwindxqw.github.io/assets/lightbox.js'></script>", "head": "", "ogImage": "https://github.com/junwindxqw.png", "createdDate": "2026-03-29", "dateLabelColor": "#1f883d"}, "P16": {"htmlDir": "docs/post/MySQL-ci-pan-kong-jian-zhan-yong-cha-xun.html", "labels": ["mysql"], "postTitle": "MySQL\u78c1\u76d8\u7a7a\u95f4\u5360\u7528\u67e5\u8be2", "postUrl": "post/MySQL-ci-pan-kong-jian-zhan-yong-cha-xun.html", "postSourceUrl": "https://github.com/junwindxqw/junwindxqw.github.io/issues/16", "commentNum": 0, "wordCount": 1362, "description": "\u5404\u4e2a\u5e93\u5360\u7528\u7a7a\u95f4\uff1a\n```sql\nSELECT \n  table_schema AS \u6570\u636e\u5e93\u540d,\n  ROUND(SUM(data_length + index_length) / 1024 / 1024 / 1024, 2) AS \u5360\u7528_G\nFROM information_schema.TABLES\nGROUP BY table_schema\nORDER BY \u5360\u7528_G DESC;\n```\n\n\u67d0\u4e2a\u5e93\u4e0b\uff0c\u6240\u6709\u7684\u8868\uff0c\u5360\u7528\u7a7a\u95f4\u5927\u5c0f\uff08\u6309\u5927\u5230\u5c0f\u6392\u5217\uff09\uff1a\n```sql\nSELECT\n  table_name AS \u8868\u540d,\n  ROUND((data_length + index_length) / 1024 / 1024 / 1024, 2) AS \u603b\u5360\u7528_G,\n  ROUND(data_length / 1024 / 1024 / 1024, 2) AS \u6570\u636e_G,\n  ROUND(index_length / 1024 / 1024 / 1024, 2) AS \u7d22\u5f15_G,\n  table_rows AS \u884c\u6570\nFROM information_schema.TABLES\nWHERE table_schema = '\u6211\u7684\u5e93\u540d\u79f0'\n  AND table_type = 'BASE TABLE'\nORDER BY (data_length + index_length) DESC;\n```\n\n\u67d0\u4e2a\u5e93\u4e0b\uff0c\u6240\u6709\u7684\u8868\uff0c\u7d22\u5f15\u5360\u7528\u7a7a\u95f4\u5927\u5c0f\uff08\u4ece\u5927\u5230\u5c0f\u6392\u5217\uff09\uff1a\n```sql\nSELECT\n  table_name AS \u8868\u540d,\n  ROUND(index_length / 1024 / 1024 / 1024, 2) AS \u7d22\u5f15\u5360\u7528_G,\n  ROUND(data_length / 1024 / 1024 / 1024, 2) AS \u6570\u636e\u5360\u7528_G,\n  ROUND((data_length + index_length) / 1024 / 1024 / 1024, 2) AS \u603b\u5360\u7528_G\nFROM information_schema.TABLES\nWHERE table_schema = 'xxxxxxxx'  -- \u4f60\u7684\u5e93\u540d\n  AND table_type = 'BASE TABLE'\nORDER BY index_length DESC;  -- \u6309\u7d22\u5f15\u5927\u5c0f\u6392\u5e8f\n```\n\n\u67d0\u4e2a\u5e93\u4e0b\uff0c\u67d0\u5f20\u8868\u7684\u6240\u5360\u7a7a\u95f4\u5927\u5c0f\uff1a\n```sql\nSELECT\n  table_name AS \u8868\u540d,\n  ROUND((data_length + index_length) / 1024 / 1024 / 1024, 2) AS \u603b\u5360\u7528_G,\n  ROUND(data_length / 1024 / 1024 / 1024, 2) AS \u6570\u636e_G,\n  ROUND(index_length / 1024 / 1024 / 1024, 2) AS \u7d22\u5f15_G,\n  table_rows AS \u884c\u6570\nFROM information_schema.TABLES\nWHERE table_schema = 'xxxx'  -- \u4f60\u7684\u5e93\u540d\n  AND table_name = 'xxxxx';  -- \u4f60\u8981\u67e5\u7684\u8868\n```\n\n\n\n\n\n\n\u3002", "top": 0, "createdAt": 1774860370, "style": "", "script": "<script src='https://junwindxqw.github.io/assets/backtop.js'></script><script src='https://junwindxqw.github.io/assets/articletoc.js'></script><script src='https://junwindxqw.github.io/assets/lightbox.js'></script>", "head": "", "ogImage": "https://github.com/junwindxqw.png", "createdDate": "2026-03-30", "dateLabelColor": "#1f883d"}, "P17": {"htmlDir": "docs/post/you-hua-MySQL-ci-pan-kong-jian-zhan-yong.html", "labels": ["mysql"], "postTitle": "\u4f18\u5316MySQL\u78c1\u76d8\u7a7a\u95f4\u5360\u7528", "postUrl": "post/you-hua-MySQL-ci-pan-kong-jian-zhan-yong.html", "postSourceUrl": "https://github.com/junwindxqw/junwindxqw.github.io/issues/17", "commentNum": 0, "wordCount": 832, "description": "\u9996\u5148\u8bf4\u4e00\u4e0b\uff0c\u6211\u7684MySQL\u662f\u963f\u91cc\u4e91RDS\uff0c\u5e93\u6570\u636e\u672c\u8eab\u5360\u7528300G\u591a\uff0c\u7136\u540e\u6211\u5728\u63a7\u5236\u53f0\u67e5\u8be2\u5230\u603b\u4f53\u5360\u7528510G\u591a\u3002", "top": 0, "createdAt": 1774864409, "style": "", "script": "<script src='https://junwindxqw.github.io/assets/backtop.js'></script><script src='https://junwindxqw.github.io/assets/articletoc.js'></script><script src='https://junwindxqw.github.io/assets/lightbox.js'></script>", "head": "", "ogImage": "https://github.com/junwindxqw.png", "createdDate": "2026-03-30", "dateLabelColor": "#1f883d"}, "P18": {"htmlDir": "docs/post/a-li-yun-RDS-zhong-\uff0c-you-mei-you-yi-jian-zi-dong-zhi-xing-OPTIMIZE TABLE xx -de-\uff1f.html", "labels": ["mysql"], "postTitle": "\u963f\u91cc\u4e91RDS\u4e2d\uff0c\u6709\u6ca1\u6709\u4e00\u952e\u81ea\u52a8\u6267\u884cOPTIMIZE TABLE xx \u7684\uff1f", "postUrl": "post/a-li-yun-RDS-zhong-%EF%BC%8C-you-mei-you-yi-jian-zi-dong-zhi-xing-OPTIMIZE%20TABLE%20xx%20-de-%EF%BC%9F.html", "postSourceUrl": "https://github.com/junwindxqw/junwindxqw.github.io/issues/18", "commentNum": 0, "wordCount": 360, "description": "\u67